{
  "name": "booth-plus",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "rollup": "4.53.2",
    "vite": "7.2.2"
  },
  "engines": {
    "bun": ">=1.3.1",
    "node": ">=22"
  },
  "scripts": {
    "dev": "bun run --parallel --filter \"@booth-plus/*\" dev",
    "dev:extension": "bun run --filter @booth-plus/extension dev",
    "dev:backend": "bun run --filter @booth-plus/backend dev",
    "db:migrate": "bun run --filter @booth-plus/backend db:migrate",
    "db:migration:create": "bun run --filter @booth-plus/backend db:migration:create",
    "test:integration": "bun run --filter @booth-plus/backend test:integration",
    "docker:build:backend": "docker build -f apps/backend/Dockerfile -t booth-plus-backend:local .",
    "deploy:build": "docker compose --env-file deploy/oci/.env -f deploy/oci/compose.yaml build backend",
    "deploy:pull": "docker compose --env-file deploy/oci/.env -f deploy/oci/compose.yaml pull backend caddy",
    "deploy:migrate": "docker compose --env-file deploy/oci/.env -f deploy/oci/compose.yaml --profile migrate run --rm --no-deps --pull never migrate",
    "deploy:backend": "docker compose --env-file deploy/oci/.env -f deploy/oci/compose.yaml up -d --no-build --pull missing backend caddy",
    "build": "bun run --filter \"@booth-plus/*\" build",
    "build:extension": "bun run --filter @booth-plus/extension build",
    "build:backend": "bun run --filter @booth-plus/backend build",
    "compile": "bun run --filter \"@booth-plus/*\" compile",
    "test": "bun run --if-present --filter \"@booth-plus/*\" test",
    "check": "bun run compile && bun run test",
    "zip": "bun run --filter @booth-plus/extension zip",
    "zip:firefox": "bun run --filter @booth-plus/extension zip:firefox"
  }
}
