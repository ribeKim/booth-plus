{
	email {$ACME_EMAIL}
}

{$APP_DOMAIN} {
	encode zstd gzip

	reverse_proxy backend:3000 {
		header_up X-Forwarded-For {remote_host}
		health_uri /api/health/storage
		health_interval 30s
		health_timeout 5s
	}

	log {
		output stdout
		format json
	}
}

{$ADMIN_DOMAIN} {
	encode zstd gzip

	handle_path /api-target/prod/* {
		reverse_proxy https://booth-plus.ribe.moe {
			header_up Host booth-plus.ribe.moe
			header_up X-Forwarded-For {remote_host}
		}
	}

	handle_path /api-target/dev/* {
		reverse_proxy https://dev.booth-plus.ribe.moe {
			header_up Host dev.booth-plus.ribe.moe
		}
	}

	handle {
		reverse_proxy admin:8080 {
			health_uri /health
			health_interval 30s
			health_timeout 5s
		}
	}

	log {
		output stdout
		format json
	}
}
