{
	email {$ACME_EMAIL}
}

{$APP_DOMAIN} {
	encode zstd gzip

	@admin-root path /admin
	redir @admin-root /admin/ 308

	handle_path /admin/* {
		reverse_proxy admin:8080 {
			health_uri /health
			health_interval 30s
			health_timeout 5s
		}
	}

	handle {
		reverse_proxy backend:3000 {
			header_up X-Forwarded-For {remote_host}
			health_uri /api/health/storage
			health_interval 30s
			health_timeout 5s
		}
	}

	log {
		output stdout
		format json
	}
}
