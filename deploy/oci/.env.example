# Public hostname routed to the OCI VM. Caddy obtains and renews its certificate.
# Keep this on a new hostname until every extension API route has been implemented.
# Do not point vbt.kamyu.me at this scaffold.
APP_DOMAIN=booth-plus.ribe.moe
ACME_EMAIL=ops@example.com
CORS_ORIGINS=https://booth.pm,https://*.booth.pm,chrome-extension://hafbafjoecfjdlhjilpakabocglkaegj
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=300
RATE_LIMIT_WRITE_MAX_REQUESTS=60

# Build locally with this tag, or replace it with one immutable registry tag/digest.
# The backend and one-shot migrator always use this exact same image reference.
BACKEND_IMAGE=booth-plus-backend:local

# Absolute host paths to two different PostgreSQL URL files. Keep the long-running
# application role free of DDL privileges; reserve the migration role for one-shot use.
# Each file contains one postgresql:// URL using the OCI primary FQDN.
DATABASE_URL_HOST_FILE=/etc/booth-plus/secrets/database-url
MIGRATION_DATABASE_URL_HOST_FILE=/etc/booth-plus/secrets/migration-database-url

# Absolute path on the OCI VM. The file is mounted read-only into the containers.
DATABASE_SSL_CA_HOST_FILE=/etc/booth-plus/oci-postgresql-ca.pem
