{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "booth-plus-backend",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-10",
  "minify": true,
  "workers_dev": true,
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "migrations_dir": "migrations"
    }
  ],
  "vars": {
    "CORS_ORIGINS": "https://booth.pm,https://*.booth.pm,chrome-extension://hafbafjoecfjdlhjilpakabocglkaegj"
  }
}
