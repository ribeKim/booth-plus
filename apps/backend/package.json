{
  "name": "@booth-plus/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.3.1",
    "node": ">=22"
  },
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build ./src/index.ts ./scripts/migrate.ts --target bun --packages external --outdir dist --sourcemap=external",
    "db:migrate": "bun run scripts/migrate.ts",
    "db:migration:create": "bun x node-pg-migrate create --migration-file-language sql --migration-filename-format utc --migrations-dir migrations",
    "compile": "bun x tsc --noEmit -p tsconfig.json",
    "test": "bun x vitest run --config vitest.config.ts",
    "test:integration": "bun x vitest run --config vitest.integration.config.ts",
    "test:watch": "bun x vitest --config vitest.config.ts"
  },
  "dependencies": {
    "hono": "4.12.29",
    "node-pg-migrate": "8.0.4",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.1",
    "@types/node": "22.19.1",
    "@types/pg": "8.20.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
