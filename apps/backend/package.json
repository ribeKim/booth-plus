{
  "name": "@booth-plus/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "bun x tsx watch src/server.ts",
    "build": "bun x tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "compile": "bun x tsc --noEmit -p tsconfig.json",
    "test": "bun x tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "tsx": "^4.20.0",
    "typescript": "^5.9.2"
  }
}
