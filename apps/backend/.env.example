HOST=0.0.0.0
PORT=3000
CORS_ORIGINS=http://localhost:3000,https://booth.pm,https://*.booth.pm,chrome-extension://hafbafjoecfjdlhjilpakabocglkaegj
SHUTDOWN_GRACE_MS=25000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=300
RATE_LIMIT_WRITE_MAX_REQUESTS=60

DATABASE_URL=postgresql://booth_plus:local_password@127.0.0.1:5432/booth_plus
# In containers, prefer DATABASE_URL_FILE=/run/secrets/database_url instead.
DATABASE_SSL_MODE=disable
# Required for OCI PostgreSQL with DATABASE_SSL_MODE=verify-full.
# DATABASE_SSL_CA_FILE=/run/secrets/oci-postgresql-ca.pem
DATABASE_POOL_MAX=10
DATABASE_CONNECT_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_STATEMENT_TIMEOUT_MS=5000
DATABASE_MIGRATION_TIMEOUT_MS=900000
DATABASE_MAX_LIFETIME_SECONDS=300
